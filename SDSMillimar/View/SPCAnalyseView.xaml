<Window
    x:Class="SDSMillimar.View.SPCAnalyseView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cm="clr-namespace:SDSMillimar.Common"
    xmlns:cv="clr-namespace:SDSMillimar.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:SDSMillimar.View"
    xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tk="clr-namespace:SDSMillimar.Utils"
    xmlns:uc="clr-namespace:SDSMillimar.UserControls"
    Title="均值极差图"
    d:DesignHeight="450"
    d:DesignWidth="800"
    hc:Dialog.Token="{x:Static tk:DialogTokens.SPCAnalyseView}"
    mc:Ignorable="d">
    <i:Interaction.Triggers>
        <i:EventTrigger>
            <i:InvokeCommandAction Command="{Binding LoadedCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid
        x:Name="SpcRootGrid"
        Grid.Row="1"
        Margin="5"
        Background="#6e576b">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.3*" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid Margin="5,5,0,5" Background="#eeeeee">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Padding="5" Background="#095fa8">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="配置信息" />
            </Border>
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <StackPanel
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    hc:TitleElement.TitleWidth="80">
                    <Border
                        Margin="4"
                        Background="White"
                        Effect="{StaticResource EffectShadow2}">
                        <hc:ComboBox
                            Margin="6"
                            hc:InfoElement.Placeholder="选择工艺"
                            hc:InfoElement.ShowClearButton="True"
                            hc:InfoElement.Title="工艺"
                            hc:TitleElement.TitlePlacement="Left"
                            AutoComplete="True"
                            DisplayMemberPath="TechnologyName"
                            IsEditable="True"
                            ItemsSource="{Binding Technologys}"
                            SelectedValue="{Binding SelectedTechnologyId, Mode=TwoWay}"
                            SelectedValuePath="Id" />
                    </Border>

                    <Border
                        Margin="4"
                        Background="White"
                        Effect="{StaticResource EffectShadow2}">
                        <hc:ComboBox
                            Margin="6"
                            hc:InfoElement.Placeholder="选择测量项目"
                            hc:InfoElement.ShowClearButton="True"
                            hc:InfoElement.Title="测量项目"
                            hc:TitleElement.TitlePlacement="Left"
                            AutoComplete="True"
                            DisplayMemberPath="ParamValue"
                            IsEditable="True"
                            IsEnabled="{Binding TechnologyParamsEnabled}"
                            ItemsSource="{Binding TechnologyParams}"
                            SelectedValue="{Binding SelectedTechnologyParamsParamName, Mode=TwoWay}"
                            SelectedValuePath="ParamName" />
                    </Border>

                    <Border
                        Margin="4"
                        Background="White"
                        Effect="{StaticResource EffectShadow2}">
                        <hc:NumericUpDown
                            Margin="6"
                            hc:InfoElement.Placeholder="请输入子组大小"
                            hc:TitleElement.Title="子组大小"
                            hc:TitleElement.TitlePlacement="Left"
                            IsEnabled="{Binding IsAdd}"
                            Minimum="2"
                            Style="{StaticResource NumericUpDownExtend}"
                            Value="{Binding SubgroupNum, Mode=TwoWay}" />
                    </Border>

                    <Border
                        Margin="4"
                        Background="White"
                        Effect="{StaticResource EffectShadow2}">
                        <hc:NumericUpDown
                            Margin="6"
                            hc:InfoElement.Placeholder="请输入子组数"
                            hc:TitleElement.Title="子组数"
                            hc:TitleElement.TitlePlacement="Left"
                            IsEnabled="{Binding IsAdd}"
                            Minimum="2"
                            Style="{StaticResource NumericUpDownExtend}"
                            Value="{Binding SamplesNum, Mode=TwoWay}" />
                    </Border>

                    <Border
                        Margin="4"
                        Background="White"
                        Effect="{StaticResource EffectShadow2}">

                        <hc:DateTimePicker
                            Margin="6"
                            hc:InfoElement.Placeholder="请选择要查询的开始时间"
                            hc:InfoElement.Title="开始时间"
                            hc:InfoElement.TitlePlacement="Left"
                            SelectedDateTime="{Binding StartTime, Mode=TwoWay}"
                            Style="{StaticResource DateTimePickerPlus}" />
                    </Border>

                    <Border
                        Margin="4"
                        Background="White"
                        Effect="{StaticResource EffectShadow2}">
                        <hc:DateTimePicker
                            Margin="6"
                            hc:InfoElement.Placeholder="请选择要查询的结束时间"
                            hc:InfoElement.Title="结束时间"
                            hc:InfoElement.TitlePlacement="Left"
                            SelectedDateTime="{Binding EndTime, Mode=TwoWay}"
                            Style="{StaticResource DateTimePickerPlus}" />
                    </Border>


                    <Grid
                        Margin="4"
                        Background="White"
                        Effect="{StaticResource EffectShadow2}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button
                            Margin="6"
                            Command="{Binding BuildXBarRCommand}"
                            Content="生成Xbar-R控制图" />
                        <Button
                            Grid.Column="1"
                            Width="100"
                            Height="30"
                            Command="{Binding ExportBmpCommand}"
                            Content="导出BMP" />
                    </Grid>
                </StackPanel>


            </Grid>

        </Grid>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>


            <Grid Margin="5,5,5,0" Background="White">
                <DataGrid
                    x:Name="dataGridSubgroups"
                    Grid.Row="1"
                    hc:DataGridAttach.CanUnselectAllWithBlankArea="True"
                    AutoGenerateColumns="False"
                    HeadersVisibility="Column"
                    ItemsSource="{Binding Subgroups}"
                    RowHeaderWidth="60"
                    RowHeight="35" />
            </Grid>
            <Grid
                Grid.Row="1"
                Margin="5"
                Background="White">
                <!--<uc:CurveControl
                    LegendItems="{Binding LegendItems}"
                    SeriesData="{Binding LineSeriesCollectionALL, UpdateSourceTrigger=PropertyChanged}"
                    XMax="{Binding XMax, UpdateSourceTrigger=PropertyChanged}"
                    XMin="{Binding XMin, UpdateSourceTrigger=PropertyChanged}" />-->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  ================= X̄ 图 =================  -->
                    <lvc:CartesianChart
                        Grid.Row="0"
                        DisableAnimations="True"
                        Series="{Binding XBarSeries}">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Title="样本" Labels="{Binding XBarLabels}" />
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="均值" LabelFormatter="{Binding YFormatter}" />
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>

                    <!--  ================= R 图 =================  -->
                    <lvc:CartesianChart
                        Grid.Row="1"
                        DisableAnimations="True"
                        Series="{Binding RSeries}">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Title="样本" Labels="{Binding RLabels}" />
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="极差" LabelFormatter="{Binding YFormatter}" />
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </Grid>


            </Grid>
        </Grid>
    </Grid>
</Window>
