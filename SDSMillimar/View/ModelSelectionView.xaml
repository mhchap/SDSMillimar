<Window
    x:Class="SDSMillimar.View.ModelSelectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:SDSMillimar.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tk="clr-namespace:SDSMillimar.Utils"
    xmlns:vm="clr-namespace:SDSMillimar.ViewModel"
    Title="型号选择"
    Width="700"
    Height="300"
    hc:Dialog.Token="{x:Static tk:DialogTokens.ModelSelectionView}"
    Background="{DynamicResource RegionBrush}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <i:Interaction.Triggers>
        <i:EventTrigger>
            <i:InvokeCommandAction Command="{Binding LoadedCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Grid Background="#eeeeee">

            <hc:ElementGroup
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Layout="Stack"
                Orientation="Horizontal">
                <hc:ComboBox
                    Width="300"
                    hc:InfoElement.Necessary="True"
                    hc:InfoElement.Placeholder="输入零件编号模糊匹配"
                    hc:InfoElement.ShowClearButton="True"
                    hc:InfoElement.Title="选择零件"
                    hc:TitleElement.TitlePlacement="Left"
                    AutoComplete="True"
                    DisplayMemberPath="ProductName"
                    IsEditable="True"
                    ItemsSource="{Binding Products}"
                    SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                    SelectedValuePath="Id" />
                <hc:ComboBox
                    Width="300"
                    Margin="20,6,0,0"
                    hc:InfoElement.Necessary="True"
                    hc:InfoElement.Placeholder="输入零件编号模糊匹配"
                    hc:InfoElement.ShowClearButton="True"
                    hc:InfoElement.Title="选择工艺"
                    hc:TitleElement.TitlePlacement="Left"
                    AutoComplete="True"
                    DisplayMemberPath="TechnologyName"
                    IsEditable="True"
                    IsEnabled="{Binding TechnologyEnabled}"
                    ItemsSource="{Binding TechnologyDtos}"
                    SelectedItem="{Binding SelectedTechnologyDto, Mode=TwoWay}"
                    SelectedValuePath="TechnologyCode" />

            </hc:ElementGroup>
        </Grid>
        <StackPanel
            Grid.Row="1"
            Margin="20"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="100"
                Command="{Binding ConfirmCommand}"
                Content="确认"
                Style="{StaticResource ButtonPrimary}" />
            <Button
                Width="100"
                Margin="8,0,0,0"
                Command="{Binding CloseCommand}"
                Content="关闭"
                Style="{StaticResource ButtonInfo}" />
        </StackPanel>
    </Grid>
</Window>
