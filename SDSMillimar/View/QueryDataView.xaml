<Window
    x:Class="SDSMillimar.View.QueryDataView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:SDSMillimar.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tk="clr-namespace:SDSMillimar.Utils"
    xmlns:vm="clr-namespace:SDSMillimar.ViewModel"
    Title="历史数据管理"
    hc:Dialog.Token="{x:Static tk:DialogTokens.QueryDataView}"
    Background="{DynamicResource RegionBrush}"
    WindowStartupLocation="CenterOwner"
    WindowState="Maximized"
    mc:Ignorable="d">
    <i:Interaction.Triggers>
        <i:EventTrigger>
            <i:InvokeCommandAction Command="{Binding LoadedCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Window.DataContext>
        <vm:QueryDataViewModel />
    </Window.DataContext>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <hc:Card
            Margin="8"
            BorderThickness="0"
            Effect="{StaticResource EffectShadow2}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <UniformGrid
                    Margin="8,0,0,0"
                    HorizontalAlignment="Left"
                    Columns="5">
                    <hc:ComboBox
                        Height="30"
                        hc:InfoElement.Placeholder="输入零件编号模糊匹配"
                        hc:InfoElement.ShowClearButton="True"
                        hc:InfoElement.Title="零件"
                        hc:TitleElement.TitlePlacement="Left"
                        AutoComplete="True"
                        DisplayMemberPath="ProductName"
                        IsEditable="True"
                        ItemsSource="{Binding Products}"
                        SelectedValue="{Binding ProductId, Mode=TwoWay}"
                        SelectedValuePath="Id" />
                    <hc:ComboBox
                        Height="30"
                        hc:InfoElement.Placeholder="输入零件编号模糊匹配"
                        hc:InfoElement.ShowClearButton="True"
                        hc:InfoElement.Title="工艺"
                        hc:TitleElement.TitlePlacement="Left"
                        AutoComplete="True"
                        DisplayMemberPath="TechnologyName"
                        IsEditable="True"
                        ItemsSource="{Binding Technologys}"
                        SelectedValue="{Binding TechnologyId, Mode=TwoWay}"
                        SelectedValuePath="Id" />
                    <hc:ComboBox
                        Height="30"
                        hc:InfoElement.Placeholder="请选择状态"
                        hc:InfoElement.ShowClearButton="True"
                        hc:InfoElement.Title="状态"
                        hc:TitleElement.TitlePlacement="Left"
                        AutoComplete="True"
                        DisplayMemberPath="Name"
                        IsEditable="True"
                        ItemsSource="{Binding StatusList}"
                        SelectedValue="{Binding SelectedStatus}"
                        SelectedValuePath="Value" />

                    <hc:DateTimePicker
                        Height="30"
                        hc:InfoElement.Placeholder="请选择要查询的开始时间"
                        hc:InfoElement.Title="开始时间"
                        hc:InfoElement.TitlePlacement="Left"
                        hc:InfoElement.TitleWidth="auto"
                        SelectedDateTime="{Binding StartTime, Mode=TwoWay}"
                        Style="{StaticResource DateTimePickerPlus}" />
                    <hc:DateTimePicker
                        Height="30"
                        hc:InfoElement.Placeholder="请选择要查询的结束时间"
                        hc:InfoElement.Title="结束时间"
                        hc:InfoElement.TitlePlacement="Left"
                        hc:InfoElement.TitleWidth="auto"
                        SelectedDateTime="{Binding EndTime, Mode=TwoWay}"
                        Style="{StaticResource DateTimePickerPlus}" />

                </UniformGrid>
                <StackPanel
                    Grid.Column="1"
                    Margin="0,0,8,0"
                    Orientation="Horizontal">

                    <Button
                        Width="100"
                        Margin="5"
                        Command="{Binding QueryCommand}"
                        Content="查询"
                        Style="{StaticResource ButtonPrimary}" />
                    <Button
                        Width="100"
                        Margin="5"
                        Command="{Binding ResetKeywordCommand}"
                        Content="重置" />
                </StackPanel>
            </Grid>



        </hc:Card>
        <hc:Card
            Grid.Row="1"
            Margin="8"
            BorderThickness="0"
            Effect="{StaticResource EffectShadow2}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <StackPanel
                    Margin="8"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button
                        Width="100"
                        Command="{Binding ExportCommand}"
                        Content="导出Excel"
                        Style="{StaticResource ButtonPrimary}" />

                </StackPanel>
                <DataGrid
                    Grid.Row="1"
                    hc:DataGridAttach.CanUnselectAllWithBlankArea="True"
                    AutoGenerateColumns="False"
                    HeadersVisibility="Column"
                    ItemsSource="{Binding Datas}"
                    RowHeaderWidth="60"
                    SelectedItem="{Binding SelectedData, Mode=TwoWay}"
                    Style="{StaticResource DataGrid.Small}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding CreateTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Header="生产时间" />
                        <DataGridTextColumn Binding="{Binding Barcode}" Header="条码" />
                        <DataGridTextColumn Binding="{Binding ProductName}" Header="零件" />
                        <DataGridTextColumn Binding="{Binding TechnologyName}" Header="工艺" />
                        <DataGridTemplateColumn Header="状态">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="不合格" />
                                                <Setter Property="Foreground" Value="Red" />

                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="True">
                                                        <Setter Property="Text" Value="合格" />
                                                        <Setter Property="Foreground" Value="Green" />
                                                    </DataTrigger>
                                                </Style.Triggers>

                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Binding="{Binding M1, StringFormat={}{0:F4}}" Header="一档直径">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Black" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding M1Status}" Value="False">
                                            <Setter Property="Foreground" Value="Red" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding M2, StringFormat={}{0:F4}}" Header="二档直径">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Black" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding M2Status}" Value="False">
                                            <Setter Property="Foreground" Value="Red" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding M3, StringFormat={}{0:F4}}" Header="三档直径">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Black" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding M3Status}" Value="False">
                                            <Setter Property="Foreground" Value="Red" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding M4, StringFormat={}{0:F4}}" Header="四档直径">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Black" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding M4Status}" Value="False">
                                            <Setter Property="Foreground" Value="Red" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding M5, StringFormat={}{0:F4}}" Header="五档直径">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Black" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding M5Status}" Value="False">
                                            <Setter Property="Foreground" Value="Red" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding M6, StringFormat={}{0:F4}}" Header="一档圆度">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Black" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding M6Status}" Value="False">
                                            <Setter Property="Foreground" Value="Red" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding M7, StringFormat={}{0:F4}}" Header="二档圆度">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Black" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding M7Status}" Value="False">
                                            <Setter Property="Foreground" Value="Red" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding M8, StringFormat={}{0:F4}}" Header="三档圆度">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Black" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding M8Status}" Value="False">
                                            <Setter Property="Foreground" Value="Red" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding M9, StringFormat={}{0:F4}}" Header="四档圆度">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Black" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding M9Status}" Value="False">
                                            <Setter Property="Foreground" Value="Red" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding M10, StringFormat={}{0:F4}}" Header="五档圆度">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Black" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding M10Status}" Value="False">
                                            <Setter Property="Foreground" Value="Red" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding M11, StringFormat={}{0:F4}}" Header="一档跳动">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Black" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding M11Status}" Value="False">
                                            <Setter Property="Foreground" Value="Red" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding M12, StringFormat={}{0:F4}}" Header="二档跳动">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Black" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding M12Status}" Value="False">
                                            <Setter Property="Foreground" Value="Red" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding M13, StringFormat={}{0:F4}}" Header="三档跳动">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Black" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding M13Status}" Value="False">
                                            <Setter Property="Foreground" Value="Red" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding M14, StringFormat={}{0:F4}}" Header="四档跳动">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Black" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding M14Status}" Value="False">
                                            <Setter Property="Foreground" Value="Red" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding M15, StringFormat={}{0:F4}}" Header="五档跳动">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Black" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding M15Status}" Value="False">
                                            <Setter Property="Foreground" Value="Red" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!--<DataGridTextColumn Binding="{Binding ParamValue}" Header="参数名称" />-->
                        <!--<DataGridTextColumn Binding="{Binding MeasureType}" Header="测量类型" />
                        <DataGridTextColumn Binding="{Binding MeasureValue}" Header="测量值" />
                        <DataGridTextColumn Binding="{Binding TargetValue}" Header="目标值" />
                        <DataGridTextColumn Binding="{Binding UpperTolerance}" Header="上公差" />
                        <DataGridTextColumn Binding="{Binding LowerTolerance}" Header="下公差" />
                        <DataGridTextColumn Binding="{Binding GroupUuid}" Header="分组ID" />-->

                        <!--<DataGridTextColumn Binding="{Binding UpdateTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Header="修改时间" />-->
                    </DataGrid.Columns>
                </DataGrid>
                <hc:LoadingCircle Grid.Row="1" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />
            </Grid>

        </hc:Card>
        <hc:Card
            Grid.Row="2"
            Margin="8,0,8,8"
            BorderThickness="0"
            Effect="{StaticResource EffectShadow2}">
            <hc:Pagination
                Margin="8"
                HorizontalAlignment="Right"
                IsJumpEnabled="True"
                MaxPageCount="{Binding MaxPageCount}"
                PageIndex="{Binding PageIndex}">
                <hc:Interaction.Triggers>
                    <hc:EventTrigger EventName="PageUpdated">
                        <hc:EventToCommand Command="{Binding PageUpdatedCommand}" PassEventArgsToCommand="True" />
                    </hc:EventTrigger>
                </hc:Interaction.Triggers>
            </hc:Pagination>
        </hc:Card>
    </Grid>
</Window>
