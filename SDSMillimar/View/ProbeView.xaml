<Window
    x:Class="SDSMillimar.View.ProbeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cm="clr-namespace:SDSMillimar.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:SDSMillimar.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tk="clr-namespace:SDSMillimar.Utils"
    xmlns:uc="clr-namespace:SDSMillimar.UserControls"
    Title="选择探针"
    Width="600"
    hc:Dialog.Token="{x:Static tk:DialogTokens.ProbeView}"
    Background="{DynamicResource RegionBrush}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Grid VerticalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <ItemsControl ItemsSource="{Binding Source={x:Static cm:GlobalSession.Instance}, Path=Probes}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="2" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <uc:ProbeControl
                        Title="{Binding Title}"
                        Grid.Row="{Binding GridRow}"
                        Grid.Column="{Binding GridColumn}"
                        Margin="0,8,0,0"
                        ClickCommand="{Binding DataContext.ProbeClickCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        ClickCommandParameter="{Binding}"
                        Direction="{Binding Direction}"
                        ProbeBackground="{Binding ProbeBackground}"
                        SelectedChannel="{Binding SelectedChannel, Mode=TwoWay}"
                        Unit="{Binding Unit}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <StackPanel
            Grid.Row="1"
            Margin="20"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="100"
                Command="{Binding ConfirmCommand}"
                Content="确认"
                IsEnabled="{Binding ConfirmIsCan}"
                Style="{StaticResource ButtonPrimary}" />
            <Button
                Width="100"
                Margin="8,0,0,0"
                Command="{Binding CloseCommand}"
                Content="关闭"
                Style="{StaticResource ButtonInfo}" />
        </StackPanel>
    </Grid>
</Window>
