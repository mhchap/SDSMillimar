<UserControl
    x:Class="SDSMillimar.View.TestItemView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cm="clr-namespace:SDSMillimar.Common"
    xmlns:cv="clr-namespace:SDSMillimar.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:SDSMillimar.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:SDSMillimar.UserControls"
    xmlns:utils="clr-namespace:SDSMillimar.Utils"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <i:Interaction.Triggers>
        <i:EventTrigger>
            <i:InvokeCommandAction Command="{Binding LoadedCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <UserControl.Resources>
        <cv:OrientationToDirectionConverter x:Key="OrientationToDirectionConverter" />
        <cv:BoolToStatusConverter x:Key="BoolToStatusConverter" />
        <cv:ValueToBrushConverter x:Key="ValueToBrushConverter" />
        <cv:TestItemOffsetToWidthConverter x:Key="TestItemOffsetToWidthConverter" TotalWidth="200" />
        <Style x:Key="ContentStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Margin" Value="8" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </UserControl.Resources>
    <Grid
        Grid.Row="1"
        Margin="5"
        Background="#6e576b">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.3*" />
            <ColumnDefinition />
            <ColumnDefinition Width="0.3*" />
        </Grid.ColumnDefinitions>
        <Grid Margin="5,5,0,5" Background="#eeeeee">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Padding="5" Background="#095fa8">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="测量过程信息" />
            </Border>
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Top">
                    <Border
                        Margin="4"
                        Background="White"
                        Effect="{StaticResource EffectShadow2}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                Style="{DynamicResource ContentStyle}"
                                Text="加工工艺" />

                            <TextBlock
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                Style="{DynamicResource ContentStyle}"
                                Text="{Binding Source={x:Static cm:GlobalSession.Instance}, Path=CurrentSelectedTechnologyDto.TechnologyName}" />
                        </Grid>
                    </Border>

                    <Grid
                        Margin="4"
                        Background="White"
                        Effect="{StaticResource EffectShadow2}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Style="{DynamicResource ContentStyle}"
                            Text="零件编号" />

                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Style="{DynamicResource ContentStyle}"
                            Text="{Binding Source={x:Static cm:GlobalSession.Instance}, Path=SelectedProduct.ProductId}" />
                    </Grid>

                    <Grid
                        Margin="4"
                        Background="White"
                        Effect="{StaticResource EffectShadow2}">
                        <Grid.Style>
                            <Style TargetType="{x:Type Grid}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger
                                        Binding="{Binding IsPull, Source={x:Static cm:GlobalSession.Instance}}"
                                        Value="1">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Style="{DynamicResource ContentStyle}"
                            Text="CGK测量" />
                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Foreground="Green"
                            Style="{DynamicResource ContentStyle}"
                            Text="是" />
                    </Grid>

                    <Grid
                        Margin="4"
                        Background="White"
                        Effect="{StaticResource EffectShadow2}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Style="{DynamicResource ContentStyle}"
                            Text="零件名称" />
                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Style="{DynamicResource ContentStyle}"
                            Text="{Binding Source={x:Static cm:GlobalSession.Instance}, Path=SelectedProduct.ProductName}" />
                    </Grid>
                    <Grid
                        Margin="4"
                        Background="White"
                        Effect="{StaticResource EffectShadow2}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Style="{DynamicResource ContentStyle}"
                            Text="测量状态" />

                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Foreground="Green"
                            Style="{DynamicResource ContentStyle}"
                            Text="{Binding ProcessStateDesc}" />
                    </Grid>

                    <Grid
                        Margin="4"
                        Background="White"
                        Effect="{StaticResource EffectShadow2}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Style="{DynamicResource ContentStyle}"
                            Text="测量模式" />

                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Foreground="Green"
                            Style="{DynamicResource ContentStyle}"
                            Text="{Binding ProcessTypeDesc}" />
                    </Grid>

                    <Grid
                        Margin="4"
                        Background="White"
                        Effect="{StaticResource EffectShadow2}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Style="{DynamicResource ContentStyle}"
                            Text="测量设备状态" />

                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Foreground="Green"
                            Style="{DynamicResource ContentStyle}"
                            Text="{Binding MillimarStateDesc}" />
                    </Grid>

                    <Grid
                        Margin="4"
                        Background="White"
                        Effect="{StaticResource EffectShadow2}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                    </Grid>
                </StackPanel>
                <Border
                    Grid.Row="1"
                    Height="200"
                    VerticalAlignment="Bottom"
                    BorderThickness="1"
                    Effect="{StaticResource EffectShadow5}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Gray" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AllOk}" Value="True">
                                    <Setter Property="Background" Value="Green" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding AllOk}" Value="False">
                                    <Setter Property="Background" Value="Red" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="100"
                        Text="{Binding AllOk, Converter={StaticResource BoolToStatusConverter}}" />
                </Border>

            </Grid>

        </Grid>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="1"
                Margin="5,5,5,0"
                Background="White">
                <DataGrid
                    Grid.Row="1"
                    hc:DataGridAttach.CanUnselectAllWithBlankArea="True"
                    AutoGenerateColumns="False"
                    HeadersVisibility="Column"
                    ItemsSource="{Binding Source={x:Static cm:GlobalSession.Instance}, Path=CurrentTechnologyParamDtos}"
                    RowHeaderWidth="60"
                    RowHeight="35"
                    SelectedItem="{Binding SelectedData, Mode=TwoWay}">
                    <DataGrid.Resources>

                        <utils:BindingProxy x:Key="proxy" Data="{Binding}" />

                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Binding="{Binding ParamName}"
                            Header="参数编号"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Binding="{Binding ParamValue}"
                            Header="参数名称"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Binding="{Binding TargetValue}"
                            Header="目标值"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Binding="{Binding UpperTolerance}"
                            Header="上公差值"
                            IsReadOnly="True"
                            Visibility="{Binding Data.ToleranceColumnVisibility, Source={StaticResource proxy}}" />

                        <DataGridTextColumn
                            Binding="{Binding LowerTolerance}"
                            Header="下公差值"
                            IsReadOnly="True"
                            Visibility="{Binding Data.ToleranceColumnVisibility, Source={StaticResource proxy}}" />
                        <DataGridTextColumn
                            Binding="{Binding MeasuredValue, StringFormat={}{0:F4}}"
                            Header="测量值"
                            IsReadOnly="True" />
                        <DataGridTemplateColumn Width="200" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="5" Background="#eeeeee">

                                        <Grid Height="80">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="2" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!--  中心线  -->
                                            <Border Grid.Column="1" Background="Black" />

                                            <!--  左条  -->
                                            <Border Grid.Column="0" HorizontalAlignment="Right">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#B8860B" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="True">
                                                                <Setter Property="Background" Value="Green" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="False">
                                                                <Setter Property="Background" Value="Red" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.Width>
                                                    <MultiBinding Converter="{StaticResource TestItemOffsetToWidthConverter}" ConverterParameter="Left">
                                                        <Binding Path="TestValue" />
                                                        <Binding Path="UpperTolerance" />
                                                        <Binding Path="LowerTolerance" />
                                                        <Binding Path="MeasureType" />
                                                        <Binding Path="MeasuredValue" />
                                                        <Binding Path="CUValue" />
                                                        <Binding Path="CLValue" />
                                                        <Binding Path="IsMeasured" />
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>

                                            <!--  右条  -->
                                            <Border Grid.Column="2" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#B8860B" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="True">
                                                                <Setter Property="Background" Value="Green" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="False">
                                                                <Setter Property="Background" Value="Red" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.Width>
                                                    <MultiBinding Converter="{StaticResource TestItemOffsetToWidthConverter}" ConverterParameter="Right">
                                                        <Binding Path="TestValue" />
                                                        <Binding Path="UpperTolerance" />
                                                        <Binding Path="LowerTolerance" />
                                                        <Binding Path="MeasureType" />
                                                        <Binding Path="MeasuredValue" />
                                                        <Binding Path="CUValue" />
                                                        <Binding Path="CLValue" />
                                                        <Binding Path="IsMeasured" />
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <ItemsControl Grid.Column="2" ItemsSource="{Binding ProbeDatas}">
            <ItemsControl.Template>
                <ControlTemplate TargetType="ItemsControl">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <ItemsPresenter />
                    </ScrollViewer>
                </ControlTemplate>
            </ItemsControl.Template>
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <uc:CollectControl
                        Unit="mm"
                        ValueTextA="{Binding MeasuredValueA, StringFormat={}{0:F4}}"
                        ValueTextB="{Binding MeasuredValueB, StringFormat={}{0:F4}}">
                        <uc:CollectControl.Title>
                            <MultiBinding StringFormat="{}{0}  {1}">
                                <Binding Path="TitleA" />
                                <Binding Path="TitleB" />
                            </MultiBinding>
                        </uc:CollectControl.Title>
                    </uc:CollectControl>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>


</UserControl>
