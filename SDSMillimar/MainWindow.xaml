<Window
    x:Class="SDSMillimar.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SDSMillimar"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:SDSMillimar.ViewModel"
    xmlns:vw="clr-namespace:SDSMillimar.View"
    Width="800"
    Height="450"
    Background="{StaticResource PrimaryBrush}"
    WindowStartupLocation="CenterOwner"
    WindowState="Maximized"
    mc:Ignorable="d">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:TestItemViewModel}">
            <vw:TestItemView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TechnologyViewModel}">
            <vw:TechnologyView />
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <!--<RowDefinition Height="20" />-->
        </Grid.RowDefinitions>
        <Border Margin="5" Background="#095fa8">
            <Border.Effect>
                <DropShadowEffect
                    x:Name="RadialBorderShadow"
                    BlurRadius="20"
                    Opacity="1"
                    ShadowDepth="0"
                    Color="#6e576b" />
            </Border.Effect>
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <!--<TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="磨削电感测头检测" />-->
                <Image Width="300" Source="/Images/AI_Logo.png" />
                <StackPanel
                    Grid.Column="1"
                    Margin="20,0,0,0"
                    Orientation="Horizontal">

                    <Button
                        Margin="20,0,0,0"
                        Command="{Binding MenuCommand}"
                        CommandParameter="Home"
                        IsEnabled="{Binding MenuBtnCan}"
                        Style="{StaticResource RoundedButton}">
                        <StackPanel
                            Margin="5"
                            HorizontalAlignment="Center"
                            Orientation="Vertical">


                            <Image
                                Width="30"
                                Height="30"
                                Margin="0,0,5,0"
                                Source="/Images/clgl.png" />


                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="首页" />
                        </StackPanel>
                    </Button>
                    <Button
                        Margin="20,0,0,0"
                        Command="{Binding MenuCommand}"
                        CommandParameter="Product"
                        IsEnabled="{Binding MenuBtnCan}"
                        Style="{StaticResource RoundedButton}">
                        <StackPanel
                            Margin="5"
                            HorizontalAlignment="Center"
                            Orientation="Vertical">
                            <!--  图标  -->
                            <Image
                                Width="30"
                                Height="30"
                                Margin="0,0,5,0"
                                Source="pack://application:,,,/Images/ljgl.png" />
                            <!--  按钮文字  -->
                            <TextBlock VerticalAlignment="Center" Text="零件管理" />
                        </StackPanel>
                    </Button>
                    <Button
                        Margin="20,0,0,0"
                        Command="{Binding MenuCommand}"
                        CommandParameter="Technology"
                        IsEnabled="{Binding MenuBtnCan}"
                        Style="{StaticResource RoundedButton}">
                        <StackPanel
                            Margin="5"
                            HorizontalAlignment="Center"
                            Orientation="Vertical">
                            <!--  图标  -->
                            <Image
                                Width="30"
                                Height="30"
                                Margin="0,0,5,0"
                                Source="pack://application:,,,/Images/gygl.png" />
                            <!--  按钮文字  -->
                            <TextBlock VerticalAlignment="Center" Text="工艺管理" />
                        </StackPanel>
                    </Button>
                    <!--<Button
                        Margin="20,0,0,0"
                        Command="{Binding MenuCommand}"
                        CommandParameter="DynamicTechnology"
                        IsEnabled="{Binding MenuBtnCan}"
                        Style="{StaticResource RoundedButton}">
                        <StackPanel
                            Margin="5"
                            HorizontalAlignment="Center"
                            Orientation="Vertical">
                    -->
                    <!--  图标  -->
                    <!--
                            <Image
                                Width="30"
                                Height="30"
                                Margin="0,0,5,0"
                                Source="pack://application:,,,/Images/csgl.png" />
                    -->
                    <!--  按钮文字  -->
                    <!--
                            <TextBlock VerticalAlignment="Center" Text="动态工艺参数管理" />
                        </StackPanel>
                    </Button>-->
                    <Button
                        Margin="20,0,0,0"
                        Command="{Binding MenuCommand}"
                        CommandParameter="QueryData"
                        IsEnabled="{Binding MenuBtnCan}"
                        Style="{StaticResource RoundedButton}">
                        <StackPanel
                            Margin="5"
                            HorizontalAlignment="Center"
                            Orientation="Vertical">
                            <!--  图标  -->
                            <Image
                                Width="30"
                                Height="30"
                                Margin="0,0,5,0"
                                Source="pack://application:,,,/Images/lssj.png" />
                            <!--  按钮文字  -->
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="历史数据管理" />
                        </StackPanel>
                    </Button>
                    <Button
                        Margin="20,0,0,0"
                        Command="{Binding MenuCommand}"
                        CommandParameter="ModelSelection"
                        IsEnabled="{Binding MenuBtnCan}"
                        Style="{StaticResource RoundedButton}">
                        <StackPanel
                            Margin="5"
                            HorizontalAlignment="Center"
                            Orientation="Vertical">
                            <!--  图标  -->
                            <Image
                                Width="30"
                                Height="30"
                                Margin="0,0,5,0"
                                Source="pack://application:,,,/Images/hx.png" />
                            <!--  按钮文字  -->
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="换型" />
                        </StackPanel>
                    </Button>

                    <Button
                        Margin="20,0,0,0"
                        Command="{Binding MenuCommand}"
                        CommandParameter="SPCAnalyse"
                        IsEnabled="{Binding MenuBtnCan}"
                        Style="{StaticResource RoundedButton}">
                        <StackPanel
                            Margin="5"
                            HorizontalAlignment="Center"
                            Orientation="Vertical">
                            <Image
                                Width="30"
                                Height="30"
                                Margin="0,0,5,0"
                                Source="pack://application:,,,/Images/spc.png" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="SPC分析" />
                        </StackPanel>
                    </Button>

                    <Button
                        Margin="20,0,0,0"
                        Command="{Binding MenuCommand}"
                        CommandParameter="ProbeData"
                        IsEnabled="{Binding MenuBtnCan}"
                        Style="{StaticResource RoundedButton}">
                        <StackPanel
                            Margin="5"
                            HorizontalAlignment="Center"
                            Orientation="Vertical">
                            <Image
                                Width="30"
                                Height="30"
                                Margin="0,0,5,0"
                                Source="pack://application:,,,/Images/tzss.png" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="测量设备" />
                        </StackPanel>
                    </Button>
                    <Button
                        Margin="20,0,0,0"
                        Command="{Binding MenuCommand}"
                        CommandParameter="CGKMeasurement"
                        IsEnabled="{Binding MenuBtnCan}"
                        Style="{StaticResource RoundedButton}">
                        <StackPanel
                            Margin="5"
                            HorizontalAlignment="Center"
                            Orientation="Vertical">
                            <Image
                                Width="30"
                                Height="30"
                                Margin="0,0,5,0"
                                Source="pack://application:,,,/Images/clgl.png" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="CGK测量" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Row="1">
            <ContentControl Content="{Binding CurrentView}" />
        </Grid>
        <!--<Border Grid.Row="2" Background="White">
            <TextBlock Text="当前测量设备数量:10" />
        </Border>-->
    </Grid>
</Window>
