<UserControl
    x:Class="SDSMillimar.UserControls.CollectControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SDSMillimar.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Margin="0,5,5,0" Background="#095fa8">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <!--  左上角标题  -->
            <TextBlock
                Margin="5"
                HorizontalAlignment="Left"
                FontSize="16"
                FontWeight="Bold"
                Foreground="White"
                Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" />

            <!--  右上角单位  -->
            <TextBlock
                Grid.Column="1"
                Margin="5"
                HorizontalAlignment="Right"
                FontSize="16"
                FontWeight="Bold"
                Foreground="White"
                Text="{Binding Unit, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </Grid>

        <!--  下方值  -->
        <Border
            Grid.Row="1"
            Padding="5"
            Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    FontSize="24"
                    FontWeight="Bold"
                    Text="{Binding ValueTextA, RelativeSource={RelativeSource AncestorType=UserControl}}" />

                <TextBlock
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    FontSize="24"
                    FontWeight="Bold"
                    Text="{Binding ValueTextB, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
