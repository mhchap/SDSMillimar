<UserControl
    x:Class="SDSMillimar.UserControls.MeasurementItemControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cv="clr-namespace:SDSMillimar.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:SDSMillimar.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tk="clr-namespace:SDSMillimar.Utils"
    xmlns:vm="clr-namespace:SDSMillimar.UserControls.ViewModel"
    hc:Dialog.Token="{x:Static tk:DialogTokens.DynamicTechnologyDetailView}"
    Background="{DynamicResource RegionBrush}"
    mc:Ignorable="d">
    <i:Interaction.Triggers>
        <i:EventTrigger>
            <i:InvokeCommandAction Command="{Binding LoadedCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <UserControl.DataContext>
        <vm:MeasurementItemViewModel />
    </UserControl.DataContext>
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <cv:MeasureTypeConverter x:Key="MeasureType" />
    </UserControl.Resources>
    <hc:DialogContainer Effect="{StaticResource EffectShadow2}">
        <!--<hc:SimplePanel Width="1000">-->
        <!--<hc:TabControl
            IsScrollable="True"
            ShowOverflowButton="False"
            ShowScrollButton="True">
            <hc:TabItem Header="直径" IsSelected="True">-->
        <hc:SimplePanel Background="{DynamicResource RegionBrush}">

            <hc:Card
                Grid.Row="1"
                Margin="8"
                BorderThickness="0"
                Effect="{StaticResource EffectShadow2}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <StackPanel
                        Margin="8"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <Button
                            Width="100"
                            Command="{Binding AddProductedCommand}"
                            Content="新增零件"
                            Style="{StaticResource ButtonPrimary}" />
                        <Button
                            Width="100"
                            Margin="8,0,0,0"
                            Command="{Binding EditProductedCommand}"
                            Content="编辑"
                            IsEnabled="{Binding BtnControlCan}"
                            Style="{StaticResource ButtonInfo}" />
                        <Button
                            Width="100"
                            Margin="8,0,0,0"
                            Command="{Binding DeleteProductedCommand}"
                            Content="删除"
                            IsEnabled="{Binding BtnControlCan}"
                            Style="{StaticResource ButtonDanger}" />
                    </StackPanel>
                    <DataGrid
                        Grid.Row="1"
                        hc:DataGridAttach.CanUnselectAllWithBlankArea="True"
                        AutoGenerateColumns="False"
                        HeadersVisibility="Column"
                        ItemsSource="{Binding Datas}"
                        RowHeaderWidth="60"
                        SelectedItem="{Binding SelectedData, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Binding="{Binding ParamName}"
                                Header="参数编号"
                                IsReadOnly="True" />
                            <DataGridTextColumn
                                Binding="{Binding ParamValue}"
                                Header="参数名称"
                                IsReadOnly="True" />
                            <DataGridTextColumn
                                Binding="{Binding MeasureType, Converter={StaticResource MeasureType}}"
                                Header="测量类型"
                                IsReadOnly="True" />
                            <DataGridTextColumn Binding="{Binding TargetValue}" Header="目标值" />
                            <DataGridTextColumn Binding="{Binding UpperTolerance}" Header="上公差值" />
                            <DataGridTextColumn Binding="{Binding LowerTolerance}" Header="下公差值" />
                            <DataGridTextColumn Binding="{Binding LowerTolerance}" Header="是否启用" />

                            <DataGridTextColumn Binding="{Binding Remark}" Header="备注" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <!--<hc:LoadingCircle Grid.Row="1" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />-->
                </Grid>

            </hc:Card>
        </hc:SimplePanel>
        <!--</hc:TabItem>
            <hc:TabItem Header="圆度">
                <hc:SimplePanel Background="{DynamicResource DarkDangerBrush}" />
            </hc:TabItem>
            <hc:TabItem Header="跳动">
                <hc:SimplePanel Background="{DynamicResource PrimaryBrush}" />
            </hc:TabItem>
            <hc:TabItem Header="圆柱度">
                <hc:SimplePanel Background="{DynamicResource DarkInfoBrush}" />
            </hc:TabItem>

        </hc:TabControl>-->
        <!--</hc:SimplePanel>-->
    </hc:DialogContainer>
</UserControl>
